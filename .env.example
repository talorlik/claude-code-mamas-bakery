# ───────────────────────────────────────────────
# Game Changer — Environment Variables
# העתק קובץ זה ל-.env.local ומלא את הערכים
# (הסקריפט setup.mjs עושה את זה אוטומטית)
# ───────────────────────────────────────────────

# Supabase — New API Keys (2026)
# https://supabase.com/docs/guides/api/api-keys
# Dashboard → Project Settings → API Keys → "Publishable and secret API keys"
NEXT_PUBLIC_SUPABASE_URL=                  # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=      # sb_publishable_...  (browser-safe)
SUPABASE_SECRET_KEY=                       # sb_secret_...       (server-only, NEVER expose)

# Vercel AI Gateway
# 5$ קרדיט חינם כל חודש — https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Transactional email (order confirmations and status updates)
# Set EMAIL_ENABLED=true to send via the send-order-email Edge Function;
# leave unset/false in dev to log emails to the console instead.
EMAIL_ENABLED=                             # "true" to enable real sending
# SMTP credentials are NOT read by the app. Set them as Supabase Edge Function
# secrets so the send-order-email function can transmit:
#   supabase secrets set SMTP_HOST=... SMTP_PORT=465 SMTP_USERNAME=... \
#     SMTP_PASSWORD=... SMTP_FROM="Mom's Bakery <orders@yourdomain>"
# Configure the same SMTP account under Supabase Auth → SMTP Settings so auth
# emails (signup, password reset) also send from the bakery domain.

# Rate limiting (Upstash Redis)
# https://upstash.com — create a Redis database and copy the REST credentials.
# When unset, rate limiting no-ops (allowed for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
